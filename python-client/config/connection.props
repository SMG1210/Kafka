
[default]
bootstrap.servers=localhost:443
security.protocol=SASL_SSL
sasl.mechanism=PLAIN
sasl.username=Test
sasl.password=Test_Pass

# Use/Modify the below configs if using the certs for authentication

# Enable SSL
#security.protocol=SSL
 
# Path to the Truststore
#ssl.truststore.location=/path/to/client.truststore.jks
#ssl.truststore.password=your_truststore_password
 
# Path to the Keystore (if client authentication is required)
#ssl.keystore.location=/path/to/client.keystore.jks
#ssl.keystore.password=your_keystore_password
#ssl.key.password=your_key_password
 
# (Optional) SSL protocol and cipher settings
#ssl.endpoint.identification.algorithm=https
#ssl.protocol=TLSv1.2